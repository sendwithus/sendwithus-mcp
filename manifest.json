{
  "manifest_version": "0.4",
  "name": "sendwithus-mcp",
  "display_name": "Sendwithus",
  "version": "0.0.1",
  "description": "MCP server wrapping the Sendwithus REST API.",
  "author": {
    "name": "Sendwithus"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "node",
    "entry_point": "server.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/server.js"],
      "env": {
        "SENDWITHUS_API_KEY": "${user_config.api_key}"
      }
    }
  },
  "user_config": {
    "api_key": {
      "type": "string",
      "title": "Sendwithus API Key",
      "description": "Your Sendwithus API key (from the Sendwithus dashboard).",
      "required": true,
      "sensitive": true
    }
  },
  "tools_generated": true,
  "compatibility": {
    "runtimes": {
      "node": ">=20.0.0"
    }
  }
}
